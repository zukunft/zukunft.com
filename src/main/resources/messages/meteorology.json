  "formulas": [
    {
      "name": "definition of relative humidity",
      "expression": "\"relative humidity\" = \"vapor pressure\" / \"saturation vapor pressure\" * 100",
      "latex": "RH = \\frac{e}{e_s} \\cdot 100",
      "assigned": [
        "vapor pressure",
        "saturation vapor pressure"
      ]
    },
    {
      "name": "definition of mixing ratio",
      "expression": "\"mixing ratio\" = \"mass of water vapor\" / \"mass of dry air\"",
      "latex": "w = \\frac{m_v}{m_d}",
      "assigned": [
        "mass of water vapor",
        "mass of dry air"
      ]
    },
    {
      "name": "definition of specific humidity",
      "expression": "\"specific humidity\" = \"mass of water vapor\" / \"mass of moist air\"",
      "latex": "q = \\frac{m_v}{m}",
      "assigned": [
        "mass of water vapor",
        "mass of moist air"
      ]
    },
    {
      "name": "definition of Coriolis parameter",
      "expression": "\"Coriolis parameter\" = 2 * \"angular velocity of Earth\" * sin(\"latitude\")",
      "latex": "f = 2 \\Omega \\sin\\phi",
      "assigned": [
        "angular velocity of Earth",
        "latitude"
      ]
    },
    {
      "name": "definition of albedo",
      "expression": "\"albedo\" = \"reflected radiation\" / \"incoming radiation\"",
      "latex": "\\alpha = \\frac{R_{\\uparrow}}{R_{\\downarrow}}",
      "assigned": [
        "reflected radiation",
        "incoming radiation"
      ]
    },
