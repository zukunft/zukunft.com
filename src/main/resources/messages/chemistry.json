  "formulas": [
    {
      "name": "definition of molar mass",
      "expression": "\"molar mass\" = \"mass\" / \"mole\"",
      "latex": "M = \\frac{m}{n}"
    },
    {
      "name": "definition of molarity",
      "expression": "\"molarity\" = \"mole\" / \"volume\"",
      "latex": "c = \\frac{n}{V}"
    },
    {
      "name": "definition of molality",
      "expression": "\"molality\" = \"mole\" / \"mass\"",
      "latex": "b = \\frac{n}{m}"
    },
    {
      "name": "definition of Gibbs free energy",
      "expression": "\"Gibbs free energy\" = \"enthalpy\" - \"temperature\" * \"entropy\"",
      "latex": "G = H - T \\cdot S"
    },
    {
      "name": "definition of pH",
      "expression": "\"pH\" = - log(\"hydrogen ion concentration\")",
      "latex": "\\text{pH} = -\\log_{10}[\\text{H}^+]",
      "assigned_word": "hydrogen ion concentration"
    },
    {
      "name": "definition of pOH",
      "expression": "\"pOH\" = - log(\"hydroxide ion concentration\")",
      "latex": "\\text{pOH} = -\\log_{10}[\\text{OH}^-]",
      "assigned_word": "hydroxide ion concentration"
    },
    {
      "name": "definition of pKa",
      "expression": "\"pKa\" = - log(\"acid dissociation constant\")",
      "latex": "\\mathrm{p}K_a = -\\log_{10} K_a",
      "assigned_word": "acid dissociation constant"
    },
    {
      "name": "self-ionization of water",
      "expression": "\"pH\" + \"pOH\" = 14",
      "latex": "\\text{pH} + \\text{pOH} = 14",
      "assigned": [
        "pH",
        "pOH"
      ]
    },
    {
