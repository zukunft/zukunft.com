  "formulas": [
    {
      "name": "Ohm's law",
      "expression": "\"voltage\" = \"current\" * \"resistance\"",
      "latex": "V = I \\cdot R",
      "assigned_word": "resistor"
    },
    {
      "name": "definition of mechanical stress",
      "expression": "\"mechanical stress\" = \"force\" / \"area\"",
      "latex": "\\sigma = \\frac{F}{A}",
      "assigned_word": "mechanical stress"
    },
    {
      "name": "definition of Young's modulus",
      "expression": "\"Young's modulus\" = \"mechanical stress\" / \"strain\"",
      "latex": "E = \\frac{\\sigma}{\\varepsilon}",
      "assigned_word": "Young's modulus"
    },
    {
      "name": "definition of the factor of safety",
      "expression": "\"factor of safety\" = \"ultimate strength\" / \"mechanical stress\"",
      "latex": "\\mathrm{FoS} = \\frac{\\sigma_u}{\\sigma}",
      "assigned_word": "factor of safety"
    },
    {
      "name": "electrical power",
      "expression": "\"power\" = \"voltage\" * \"current\"",
      "latex": "P = V \\cdot I",
      "assigned_word": "power factor"
    },
    {
      "name": "definition of the Reynolds number",
      "expression": "\"Reynolds number\" = ( \"density\" * \"velocity\" * \"length\" ) / \"viscosity\"",
      "latex": "\\mathrm{Re} = \\frac{\\rho\\, v\\, L}{\\mu}",
      "assigned_word": "Reynolds number"
    },
    {
      "name": "energy stored in a capacitor",
      "expression": "\"energy\" = \"capacitance\" * \"voltage\"^2 / 2",
      "latex": "E = \\tfrac{1}{2} C V^2",
      "assigned_word": "capacitor"
    }
