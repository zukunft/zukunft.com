      "assigned_word": "company"
    },
    {
      "name": "Financial income/expense, net",
      "expression": "=\"Profit/loss on equity method investments, net\" + \"Other financial income/expense, net\" + \"Financial income\" + \"Financial expense\"",
      "assigned_word": "company"
    },
    {
      "name": "Interest income/expense, net",
      "expression": "=\"Interest income\" + \"Interest expense\"",
      "assigned_word": "company"
    },
    {
      "name": "Profit before income taxes",
      "expression": "=\"Operating Profit\" + \"Operating expenses\"  + \"Operating income\" + \"Financial income/expense, net\" + \"Interest income/expense, net\"",
      "assigned_word": "company"
    },
    {
      "name": "Net profit",
      "expression": "=\"Profit before income taxes\" + \"income taxes\" + \"Income from associates and joint ventures\"",
      "assigned_word": "company"
    },
    {
      "name": "Profit attributable to shareholders",
      "expression": "=\"Net profit\" - \"Profit attributable to non-controlling interests\"",
      "assigned_word": "company"
    },
    {
      "name": "Earnings per share",
      "expression": "= \"Profit attributable to shareholders\" / \"Number of shares\"",
      "assigned_word": "company"
    },
    {
      "name": "Price Earning ratio",
      "expression": "= \"Share price\" / \"Earnings per share\"",
      "assigned_word": "company"
    },
    {
      "name": "Target Price",
      "expression": "= \"Earnings per share\" * \"Target Price Earning Ratio\"",
      "assigned_word": "company"
    },
